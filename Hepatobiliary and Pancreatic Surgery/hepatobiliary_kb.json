  "mdt_focus_points": [
    {
      "id": "mdt_jaundice_entry",
      "trigger": "以黄疸为首发主诉",
      "focus": [
        "先判断是否合并发热、寒战、低血压或意识改变，排查胆管炎和脓毒症",
        "结合 TBil、DBil、ALT、AST、ALP、GGT、INR 和白蛋白判断是胆汁淤积型还是肝细胞损伤型",
        "影像若提示胆道扩张更支持梗阻性黄疸；无扩张不能直接排除肝门部或近端梗阻",
        "注意药物性肝损伤、病毒性肝炎、自身免疫性肝病和溶血等非手术病因",
        "若疑恶性梗阻，要把减黄、病理获取、分期和根治性治疗时序放进同一 MDT 讨论"
      ],
      "suggested_disciplines": ["肝胆外科", "消化内镜", "介入科", "感染科", "重症医学科", "肝病科", "肿瘤科"]
    }
  ],
