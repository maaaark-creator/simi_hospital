  "drugs": [
    {
      "id": "propofol",
      "name_zh": "丙泊酚",
      "class": "静脉麻醉诱导药",
      "common_routes": ["IV"],
      "common_uses": ["全麻诱导", "静脉镇静", "麻醉维持"],
      "label_reference": {
        "adult_induction_reference": "常见成人诱导参考剂量约 2-2.5 mg/kg IV，老年或 ASA III/IV 患者通常需要减量并缓慢滴定",
        "contraindications": ["对丙泊酚或制剂成分超敏"],
        "major_warnings": ["可能出现低血压", "可能出现呼吸抑制或呼吸暂停"]
      },
      "clinical_notes_inference": [
        "常用于需要快速诱导和较快苏醒的场景",
        "血流动力学脆弱患者应慎重选择并小剂量滴定"
      ],
      "source_ids": ["propofol_label"]
    },
    {
      "id": "ketamine",
      "name_zh": "氯胺酮",
      "class": "解离性麻醉药",
      "common_routes": ["IV", "IM"],
      "common_uses": ["诱导", "短小操作镇静/镇痛", "特定场景下维持"],
      "label_reference": {
        "adult_induction_reference": "IV 常见参考范围约 1-4.5 mg/kg；实际需按目的与反应滴定",
        "contraindications": ["当血压明显升高会构成严重危险时不宜使用"],
        "major_warnings": ["可能出现精神反应", "需重视分泌物和气道反应"]
      },
      "clinical_notes_inference": [
        "保留自主呼吸潜力较强，但并不等于无需气道准备",
        "对低血压倾向患者有时更有优势，但仍需个体化判断"
      ],
      "source_ids": ["ketamine_label"]
    },
    {
      "id": "rocuronium",
      "name_zh": "罗库溴铵",
      "class": "非去极化肌松药",
      "common_routes": ["IV"],
      "common_uses": ["气管插管", "术中肌松维持"],
      "label_reference": {
        "adult_intubation_reference": "常见插管参考剂量约 0.6 mg/kg IV",
        "contraindications": ["对罗库溴铵或溴离子超敏"],
        "major_warnings": ["必须具备人工通气和气道支持条件", "使用后需评估残余肌松"]
      },
      "clinical_notes_inference": [
        "常作为 RSI 中琥珀胆碱的替代选项之一",
        "术末需结合监测决定是否拮抗"
      ],
      "source_ids": ["rocuronium_label"]
    },
    {
      "id": "succinylcholine",
      "name_zh": "琥珀胆碱",
      "class": "去极化肌松药",
      "common_routes": ["IV", "IM"],
      "common_uses": ["快速序贯诱导", "短时深度肌松"],
      "label_reference": {
        "adult_intubation_reference": "常见插管参考剂量约 1 mg/kg IV",
        "contraindications": [
          "恶性高热病史或易感",
          "重大烧伤、多发创伤、广泛失神经等高钾风险状态",
          "对药物成分超敏"
        ],
        "major_warnings": ["可致严重高钾血症", "可触发恶性高热"]
      },
      "clinical_notes_inference": [
        "起效快、时程短，适合极短时间窗的插管需求",
        "使用前必须先做高钾和恶性高热风险筛查"
      ],
      "source_ids": ["succinylcholine_label"]
    }
  ],
