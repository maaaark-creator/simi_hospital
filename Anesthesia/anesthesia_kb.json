  "postop_rules": {
    "pacu_transfer_and_handoff": [
      "接受过全麻、区域麻醉或 MAC 的患者均应接受适当的术后麻醉管理。",
      "转运至 PACU 时应由熟悉病情的麻醉团队成员陪同，并在转运中持续评估和支持。",
      "到达 PACU 后应向接收护士做口头交接，记录到达时状态，并在护士正式接手前持续在场。"
    ],
    "pacu_monitoring_focus": [
      "恢复早期应持续关注氧合、通气、循环、意识水平和体温。",
      "使用合适评分系统有助于出PACU准备评估，但不能替代临床判断。",
      "出PACU责任应落实到医师或经批准的出室标准流程。"
    ],
    "source_ids": ["asa_postanesthesia_care"]
  },
