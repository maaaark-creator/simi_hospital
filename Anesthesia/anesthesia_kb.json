    "mac_definition_summary": [
      "MAC 是由合格麻醉提供者实施的特定麻醉服务，不等同于单纯中度镇静。",
      "MAC 允许根据患者与操作需求在清醒到全麻之间灵活调整深度，并要求提供者随时准备处理更深层镇静甚至全麻。",
      "MAC 包含术前评估优化、术中生命支持、气道和血流动力学管理及术后管理。"
    ],
    "glp1_guidance_summary": [
      "2024 年 10 月多学会最新指导提出：大多数择期手术患者无需常规停用 GLP-1 受体激动剂。",
      "高胃肠道风险场景需重点识别：用药升级期、明显恶心呕吐/腹胀/便秘等症状、高剂量方案或其他延迟胃排空背景。",
      "高风险患者可考虑术前 24 小时流质饮食、调整麻醉方案降低误吸风险，必要时结合胃超声或延期手术。"
    ]
  },
  "assessment_frameworks": {
    "difficult_airway_red_flags": [
      "既往困难面罩通气、困难喉镜暴露、困难插管或困难前颈部通路史。",
      "张口受限、小下颌、颈项活动受限、头颈部肿瘤/放疗后改变。",
      "肥胖、OSA、上气道解剖异常或术式本身提示气道管理风险增加。"
    ],
    "ponv_risk_clues": [
      "既往 PONV 或晕动病史。",
      "预计需要挥发性麻醉药、阿片类或术后阿片需求较高。",
      "高风险患者更应考虑多模式止吐策略，而不是单药机械应用。"
    ]
  },
